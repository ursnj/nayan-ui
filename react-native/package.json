{
  "name": "@nayan-ui/react-native-heroui",
  "version": "1.0.0",
  "description": "React Native component library configured with HeroUI Native and Uniwind.",
  "source": "./src/index.tsx",
  "main": "./dist/commonjs/index.js",
  "module": "./dist/module/index.js",
  "types": "./dist/typescript/commonjs/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "development": "./src/index.tsx",
        "types": "./dist/typescript/commonjs/src/index.d.ts",
        "default": "./dist/module/index.js"
      },
      "require": {
        "development": "./src/index.tsx",
        "types": "./dist/typescript/commonjs/src/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    },
    "./styles": "./src/styles/global.css"
  },
  "files": [
    "dist",
    "src/styles/global.css"
  ],
  "scripts": {
    "build": "rimraf dist && bob build",
    "example": "yarn workspace @nayan-ui/react-native-heroui-example",
    "clean": "rimraf dist"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "component-library",
    "reusable-components",
    "heroui-native",
    "uniwind"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ursnj/nayan-ui.git",
    "directory": "react-native"
  },
  "author": "ursnj <niranjan.devasani@gmail.com> (https://github.com/ursnj)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ursnj/nayan-ui/issues"
  },
  "homepage": "https://www.nayanui.com",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@rn-primitives/accordion": "^1.2.0",
    "@rn-primitives/alert-dialog": "^1.2.0",
    "@rn-primitives/checkbox": "^1.2.0",
    "@rn-primitives/dialog": "^1.2.0",
    "@rn-primitives/dropdown-menu": "^1.2.0",
    "@rn-primitives/label": "^1.2.0",
    "@rn-primitives/popover": "^1.2.0",
    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/progress": "^1.2.0",
    "@rn-primitives/radio-group": "^1.2.0",
    "@rn-primitives/select": "^1.2.0",
    "@rn-primitives/separator": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@rn-primitives/switch": "^1.2.0",
    "@rn-primitives/tooltip": "^1.2.0",
    "@rn-primitives/types": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo-status-bar": "^2.2.3",
    "heroui-native": "^1.0.0",
    "linkify-it": "^5.0.0",
    "lucide-react-native": "^0.525.0",
    "mdurl": "^2.0.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-toast-message": "^2.3.0",
    "react-native-wheel-color-picker": "^1.3.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "uniwind": "^1.6.0"
  },
  "devDependencies": {
    "@react-native-community/datetimepicker": "^8.3.0",
    "@react-navigation/native": "^7.1.9",
    "@types/react": "^19.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo-navigation-bar": "^4.2.4",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.18",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "^0.7.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  },
  "resolutions": {
    "@types/react": "^19.2.0"
  },
  "peerDependencies": {
    "@react-native-community/datetimepicker": "*",
    "@react-navigation/native": ">=6",
    "expo-navigation-bar": "*",
    "heroui-native": ">=1",
    "nativewind": ">=4",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": ">=2",
    "react-native-reanimated": ">=3",
    "react-native-safe-area-context": ">=4",
    "react-native-screens": ">=4",
    "react-native-svg": "*",
    "react-native-worklets": ">=0.5",
    "tailwindcss": ">=3",
    "uniwind": ">=1"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "dist",
    "targets": [
      [
        "commonjs",
        {
          "esm": true,
          "configFile": "./babel.config.js"
        }
      ],
      [
        "module",
        {
          "esm": true,
          "configFile": "./babel.config.js"
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0"
}
