{
  "extends": "../tsconfig",
  "compilerOptions": {
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noUncheckedIndexedAccess": false,
    "verbatimModuleSyntax": false,
    "types": [
      "uniwind/types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "../nativewind-env.d.ts",
    "expo-env.d.ts"
  ]
}
