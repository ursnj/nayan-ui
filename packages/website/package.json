{
  "name": "@nayan-ui/website",
  "private": true,
  "description": "Reusable UI Component Libraries for React and React Native.",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=development node server",
    "preview": "NODE_ENV=production node server",
    "debug": "node --inspect-brk server",
    "build": "rimraf dist && npm run build:client && npm run build:server",
    "build:client": "vite build --mode production --outDir dist/client",
    "build:server": "vite build --mode production --outDir dist/server --ssr src/entry-server.jsx",
    "sitemap": "npx nayan create sitemap -w http://localhost:7100 -r https://www.nayanui.com -o ./public/sitemap.xml"
  },
  "dependencies": {
    "@nayan-ui/react": "workspace:*",
    "compression": "^1.8.1",
    "express": "^4.21.2",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-code-blocks": "^0.1.6",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^1.3.0",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^6.30.1",
    "serve-static": "^2.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.5"
  },
  "license": "ISC"
}
