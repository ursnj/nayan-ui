{
  "name": "@nayan-ui/react-native",
  "version": "1.0.0",
  "description": "React Native Component Library for smooth and faster mobile application development.",
  "source": "./src/index.tsx",
  "main": "./dist/commonjs/index.js",
  "module": "./dist/module/index.js",
  "types": "./dist/typescript/commonjs/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "development": "./src/index.tsx",
        "types": "./dist/typescript/commonjs/src/index.d.ts",
        "default": "./dist/module/index.js"
      },
      "require": {
        "development": "./src/index.tsx",
        "types": "./dist/typescript/commonjs/src/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && bob build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "component-library",
    "reusable-components",
    "nayan-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ursnj/nayan-ui.git",
    "directory": "packages/react-native"
  },
  "author": "ursnj <niranjan.devasani@gmail.com> (https://github.com/ursnj)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ursnj/nayan-ui/issues"
  },
  "homepage": "https://www.nayanui.com",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "date-fns": "^4.1.0",
    "heroui-native": "latest",
    "linkify-it": "^5.0.0",
    "lucide-react-native": "^0.525.0",
    "mdurl": "^2.0.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-wheel-color-picker": "^1.3.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@react-native-community/datetimepicker": "^8.3.0",
    "@types/react": "^19.1.5",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo-navigation-bar": "^4.2.4",
    "react": "19.1.0",
    "react-native": "0.80.1",
    "react-native-builder-bob": "^0.40.13",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.1",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-svg": "^15.12.1",
    "react-native-worklets": "^0.5.1",
    "typescript": "^5.8.3",
    "uniwind": "latest"
  },
  "resolutions": {
    "@types/react": "^19.1.5"
  },
  "peerDependencies": {
    "@react-native-community/datetimepicker": "*",
    "expo-navigation-bar": "*",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": ">=2",
    "react-native-reanimated": ">=4",
    "react-native-safe-area-context": ">=5",
    "react-native-svg": "*",
    "react-native-worklets": ">=0.5",
    "uniwind": "*"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "dist",
    "targets": [
      [
        "commonjs",
        {
          "esm": true,
          "configFile": "./babel.config.js"
        }
      ],
      [
        "module",
        {
          "esm": true,
          "configFile": "./babel.config.js"
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
