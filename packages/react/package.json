{
  "name": "@nayan-ui/react",
  "sideEffects": false,
  "description": "React Component Library for smooth and faster web application development.",
  "version": "1.0.0",
  "type": "module",
  "source": "./src/index.ts",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://www.nayanui.com",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "default": "./dist/index.es.js"
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "require": "./dist/styles.css",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && vite build && tsc -p tsconfig.build.json",
    "dev": "rimraf dist && vite build --watch"
  },
  "dependencies": {
    "@heroui/react": "^3.0.0",
    "@heroui/styles": "^3.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "react-hook-form": "^7.60.0",
    "react-linkify": "^1.0.0-alpha",
    "react-select": "^5.10.2",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router-dom": ">=6.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.30.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ursnj/nayan-ui"
  },
  "keywords": [
    "react-js",
    "react-component-library",
    "react-reusable-components",
    "react-ui-library",
    "next-js-components",
    "react-vite",
    "dev-tools",
    "seo-tools",
    "nayan-ui"
  ],
  "author": {
    "name": "Niranjan Devasani",
    "email": "niranjan.devasani@gmail.com",
    "url": "https://www.ursnj.com"
  },
  "bugs": {
    "url": "https://github.com/ursnj/nayan-ui/issues"
  },
  "license": "MIT"
}
