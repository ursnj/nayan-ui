{
  "name": "@nayan-ui/react",
  "sideEffects": false,
  "description": "React Component Library for smooth and faster web application development.",
  "version": "2.0.0-beta.10",
  "type": "module",
  "source": "./src/index.ts",
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://www.nayanui.com",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.es.js",
      "default": "./dist/index.es.js"
    },
    "./styles.css": {
      "import": "./src/styles.css",
      "require": "./src/styles.css",
      "default": "./src/styles.css"
    }
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && vite build && tsc -p tsconfig.build.json",
    "dev": "rimraf dist && vite build --watch"
  },
  "dependencies": {
    "@heroui/react": "^3.0.4",
    "prism-react-renderer": "^2.4.1",
    "react-linkify": "^1.0.0-alpha",
    "react-select": "^5.10.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ursnj/nayan-ui"
  },
  "keywords": [
    "react-js",
    "react-component-library",
    "react-reusable-components",
    "react-ui-library",
    "next-js-components",
    "react-vite",
    "dev-tools",
    "seo-tools",
    "nayan-ui"
  ],
  "author": {
    "name": "Niranjan Devasani",
    "email": "niranjan.devasani@gmail.com",
    "url": "https://www.ursnj.com"
  },
  "bugs": {
    "url": "https://github.com/ursnj/nayan-ui/issues"
  },
  "license": "MIT"
}
