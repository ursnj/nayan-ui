{
  "name": "@nayan-ui/native",
  "sideEffects": false,
  "version": "2.0.0-beta.6",
  "description": "Component library for React Native.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-example",
    "clean": "del-cli lib",
    "build": "bob build",
    "typecheck": "tsc"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ursnj/nayan-ui.git"
  },
  "author": "ursnj <niranjan.devasani@gmail.com> (https://github.com/ursnj)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ursnj/nayan-ui/issues"
  },
  "homepage": "https://github.com/ursnj/nayan-ui#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "heroui-native": "^1.0.4"
  },
  "devDependencies": {
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@types/react": "^19.2.15",
    "del-cli": "^7.0.0",
    "react": "19.2.6",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-svg": "^15.12.1",
    "typescript": "^6.0.2",
    "uniwind": "^1.7.0"
  },
  "peerDependencies": {
    "@react-native-community/datetimepicker": "*",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*",
    "react-native-svg": "*",
    "react-native-worklets": "*",
    "uniwind": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-community/datetimepicker": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
