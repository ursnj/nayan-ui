{
  "name": "react-native-example",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "prebuild": "npx expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios": "xcodebuild ONLY_ACTIVE_ARCH=YES -workspace ios/ReactNativeExample.xcworkspace -UseNewBuildSystem=YES -scheme ReactNativeExample -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build -quiet",
    "build:android": "cd android && ./gradlew assembleDebug -DtestBuildType=debug -Dorg.gradle.jvmargs=-Xmx4g",
    "build:web": "expo export --platform web",
    "postinstall": "npx patch-package || true"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.10",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.13",
    "@react-native-community/datetimepicker": "^9.1.0",
    "expo": "~55.0.19",
    "expo-constants": "^55.0.15",
    "expo-dev-client": "~55.0.12",
    "expo-linking": "^55.0.14",
    "expo-router": "^55.0.13",
    "expo-screens": "^0.0.0",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.1",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "~0.8.0",
    "tailwindcss": "^4.0.0",
    "uniwind": "^1.7.0"
  },
  "private": true,
  "devDependencies": {
    "react-native-builder-bob": "^0.41.0",
    "react-native-monorepo-config": "^0.3.3"
  }
}
