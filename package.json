{
  "name": "@nayan-ui/root",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/native/example"
  ],
  "version": "1.0.0",
  "description": "Reusable Component Libraries for React and React Native.",
  "scripts": {
    "prepare": "husky install",
    "format": "prettier --write .",
    "clean": "rimraf packages/*/node_modules packages/*/dist packages/*/lib node_modules",
    "cli:build": "yarn workspace @nayan-ui/cli build",
    "react:dev": "yarn workspace @nayan-ui/react dev",
    "react:build": "yarn workspace @nayan-ui/react build",
    "native:build": "yarn workspace @nayan-ui/react-native build",
    "native:typecheck": "yarn workspace @nayan-ui/react-native typecheck",
    "native:clean": "yarn workspace @nayan-ui/react-native clean",
    "native:example": "yarn workspace @nayan-ui/react-native example",
    "website:dev": "concurrently \"yarn react:dev\" \"yarn workspace @nayan-ui/website dev\"",
    "website:build": "yarn react:build && yarn workspace @nayan-ui/website build",
    "website:start": "yarn workspace @nayan-ui/website start"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "concurrently": "^9.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,md,json}": [
      "prettier --write ."
    ]
  },
  "license": "ISC",
  "packageManager": "yarn@4.11.0"
}
